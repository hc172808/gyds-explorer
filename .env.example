# ============================================================
# GYDS Explorer Environment Configuration
# Copy this file to .env and update the values
# ============================================================

# ---------- RPC Configuration ----------
# Primary RPC endpoint for the GYDS blockchain
VITE_RPC_URL=https://rpc.netlifegy.com

# Secondary/fallback RPC endpoint
VITE_RPC_URL_2=https://rpc2.netlifegy.com

# ---------- Application Settings ----------
# Application port (default: 8080)
VITE_PORT=8080

# Application title
VITE_APP_TITLE=GYDS Explorer

# Chain ID (decimal)
VITE_CHAIN_ID=1

# Explorer base URL (used for SEO canonical URLs)
VITE_BASE_URL=https://explorer.netlifegy.com

# ---------- PostgreSQL Database ----------
# Database connection settings (used by the API server)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gyds_explorer
DB_USER=gyds_admin
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Full connection string (auto-generated by deploy script)
DATABASE_URL=postgresql://gyds_admin:CHANGE_ME_STRONG_PASSWORD@localhost:5432/gyds_explorer

# ---------- API Server ----------
# API server port
API_PORT=3001

# API base URL (frontend will call this)
VITE_API_URL=http://localhost:3001/api

# API secret key for signing tokens
API_SECRET_KEY=CHANGE_ME_RANDOM_SECRET

# ---------- Optional ----------
# Enable API rate limiting (requests per minute per IP)
API_RATE_LIMIT=100

# CORS allowed origins (comma-separated)
API_CORS_ORIGINS=http://localhost:8080,https://explorer.netlifegy.com
