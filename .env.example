# GYDS Explorer Environment Configuration
# Copy this file to .env and update the values

# Primary RPC endpoint for the GYDS blockchain
VITE_RPC_URL=https://rpc.netlifegy.com

# Secondary/fallback RPC endpoint
VITE_RPC_URL_2=https://rpc2.netlifegy.com

# Application port (default: 8080)
VITE_PORT=8080

# Application title
VITE_APP_TITLE=GYDS Explorer

# Chain ID (decimal)
VITE_CHAIN_ID=1

# Explorer base URL (used for SEO canonical URLs)
VITE_BASE_URL=https://explorer.netlifegy.com
